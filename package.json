{
  "name": "sdmx-monorepo",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:frontend": "turbo run dev --filter=sdmx-frontend-next",
    "dev:backend": "turbo run dev --filter=backend-api"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
