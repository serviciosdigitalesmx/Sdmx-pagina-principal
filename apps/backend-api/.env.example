# ===== SUPABASE Configuration =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== Server Configuration =====
PORT=5001
NODE_ENV=development

# ===== CORS Configuration =====
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com,https://*.vercel.app

# ===== Authentication & JWT =====
JWT_SECRET=your-very-long-and-random-secret-key-change-in-production

# ===== API URLs =====
APP_URL=http://localhost:3000
WEBHOOK_BASE_URL=http://localhost:5001
BACKEND_PUBLIC_URL=http://localhost:5001

# ===== Mercado Pago / Billing =====
MP_ACCESS_TOKEN=TEST-your-mercado-pago-token
MP_WEBHOOK_SECRET=your-webhook-secret-key

# ===== Features =====
TRIAL_DAYS=15

# Legacy aliases (deprecated, for backwards compatibility)
# MERCADOPAGO_ACCESS_TOKEN=TEST-your-token
# NEXT_PUBLIC_APP_URL=http://localhost:3000
